# Environment and secrets (never commit real credentials)
# -----------------------------------------------------------------------------
# .env holds live secrets — always ignored. Broader .env.* catches variants
# (.env.staging, .env.backup, .env.development, .env.test, etc.) that are easy
# to add by mistake before pushing to GitHub.
.env
.env.*
!.env.example
!.env.template
!.env.sample
!.env.dist
# allow committed “example env” variants, e.g. .env.staging.example
!.env.*.example
# direnv loads env vars from disk; often contains the same secrets as .env
.envrc
# common local override filenames
*.local.env
local.env
# cloud / API key files sometimes dropped in repo root
credentials.json
client_secret.json
service-account*.json
*-credentials.json
# private keys
*.pem
*.p12
*.pfx
id_rsa
id_ecdsa
id_ed25519

# OS
.DS_Store
Thumbs.db

